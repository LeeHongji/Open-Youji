# Youji Scheduler Configuration

# Cron schedule for supervisor sessions (default: hourly)
CRON_SCHEDULE=0 * * * *

# Path to Youji repo (default: auto-detected from scheduler location)
# REPO_DIR=/path/to/Youji

# Maximum concurrent sessions including fleet (default: 1)
MAX_CONCURRENT=5

# Number of fleet workers, 0 to disable (default: 0)
FLEET_SIZE=0

# Control API port (default: 8420)
API_PORT=8420
